# Copie para .env.local e preencha com os valores do SEU projeto Supabase.
# NUNCA versione .env.local. A service_role só existe no servidor.

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Só servidor. Se aparecer em código "use client" ou em NEXT_PUBLIC_*, o build está quebrado.
SUPABASE_SERVICE_ROLE_KEY=

# Connection string (URI) — Project Settings → Database. Usada por migrations/scripts.
SUPABASE_DB_URL=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- IA (reservado para a Fase 6; deixe em branco por ora) ---
AI_PROVIDER=
AI_API_KEY=
EMBEDDING_MODEL=
CHAT_MODEL=

# Observação: o SMTP dos e-mails de autenticação é configurado no dashboard
# do Supabase (Auth → SMTP Settings), não aqui.
